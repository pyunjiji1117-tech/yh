NAVER_CLIENT_ID=your_client_id
NAVER_CLIENT_SECRET=your_client_secret

# Optional. Use a different port when running another bot copy on the same laptop.
NEWS_ALERT_PORT=8765

# Optional. If TELEGRAM_BOT_TOKEN is set, /start users are saved to the local DB.
TELEGRAM_BOT_TOKEN=

# Optional fallback/manual recipients. Separate multiple chat IDs with commas.
TELEGRAM_CHAT_ID=
TELEGRAM_CHAT_IDS=
